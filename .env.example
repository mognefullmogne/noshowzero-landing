# Supabase (create project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (create account at stripe.com, use test mode)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# Anthropic (AI chat + risk scoring)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=your@email.com

# Twilio (SMS, WhatsApp, Email notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+14155238886

# Offer token signing (generate with: openssl rand -hex 32)
OFFER_TOKEN_SECRET=your-random-hex-secret-here

# Cron job protection (set a random string, used by Vercel Cron)
CRON_SECRET=your-random-secret-here

# Twilio webhook URL (production: https://your-domain.com/api/webhooks/twilio)
TWILIO_WEBHOOK_URL=http://localhost:3000/api/webhooks/twilio

# Confirmation workflow settings
CONFIRMATION_TIMEOUT_HOURS=24
CONFIRMATION_SEND_HOURS_BEFORE=48

# Optimization engine settings (auto-apply decisions with score >= threshold)
OPTIMIZATION_AUTO_APPLY_THRESHOLD=90
